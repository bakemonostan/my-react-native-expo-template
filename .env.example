# Copy to `.env` — never commit real secrets.

APP_ENV=development
THEME_MODE=auto

APP_DISPLAY_NAME=my-rn-template
EXPO_PUBLIC_SLUG=my-rn-template
EXPO_PUBLIC_SCHEME=myrntemplate

EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_API_BASE_URL_STAGING=

IOS_BUNDLE_ID=
IOS_BUNDLE_ID_STAGING=
ANDROID_PACKAGE=
ANDROID_PACKAGE_STAGING=

# mock = local success paths (default). api = calls services/authBackend.ts routes.
EXPO_PUBLIC_AUTH_MODE=mock

# 1 = request notification permission and log native push token in dev (no EAS required).
EXPO_PUBLIC_PUSH_SETUP=0

# Optional: comma-separated hosts for Universal Links, e.g. app.example.com,www.example.com
# EXPO_PUBLIC_IOS_ASSOCIATED_DOMAINS=

EXPO_PUBLIC_APP_VERSION=
EXPO_PUBLIC_LOG_LEVEL=
