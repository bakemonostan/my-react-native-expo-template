# Copy to `.env` or `.env.local` (gitignored). Only EXPO_PUBLIC_* are embedded in the client bundle.
# Primary app config: `app.config.ts` (see https://docs.expo.dev/workflow/configuration/)

# staging | production | development
APP_ENV=development
# EXPO_PUBLIC_APP_ENV=development

# App display name, slug, scheme (optional overrides — defaults are template placeholders)
# APP_DISPLAY_NAME=My App
# EXPO_PUBLIC_SLUG=my-app
# EXPO_PUBLIC_SCHEME=myapp

# iOS / Android identifiers (optional). Staging bundle/package only apply when *_STAGING is set.
# IOS_BUNDLE_ID=com.company.app
# IOS_BUNDLE_ID_STAGING=com.company.app.staging
# ANDROID_PACKAGE=com.company.app
# ANDROID_PACKAGE_STAGING=com.company.app.staging

# Primary API base (no trailing slash unless your server expects it)
# EXPO_PUBLIC_API_BASE_URL=https://api.example.com

# When APP_ENV / EXPO_PUBLIC_APP_ENV is `staging`, this URL is used if set
# EXPO_PUBLIC_API_BASE_URL_STAGING=https://staging-api.example.com

# EXPO_PUBLIC_APP_VERSION=1.0.0
# EXPO_PUBLIC_LOG_LEVEL=info
